{
  "name": "rackula",
  "version": "0.9.4",
  "description": "Drag and drop rack visualizer",
  "author": "ggfevans",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RackulaLives/Rackula.git"
  },
  "homepage": "https://github.com/RackulaLives/Rackula",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "NODE_OPTIONS=--max-old-space-size=8192 vitest",
    "test:run": "NODE_OPTIONS=--max-old-space-size=8192 vitest run",
    "test:e2e": "playwright test",
    "test:e2e:dev": "playwright test --config playwright.dev.config.ts",
    "test:e2e:smoke": "playwright test --config playwright.smoke.config.ts",
    "test:coverage": "NODE_OPTIONS=--max-old-space-size=8192 vitest run --coverage",
    "check:compose-parity": "bash scripts/check-compose-persist-parity.sh",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "prepare": "husky",
    "process-images": "npx tsx scripts/process-images.ts",
    "generate-bundled-images": "npx tsx scripts/generate-bundled-images.ts",
    "update-contributors": "npx tsx scripts/update-contributors.ts",
    "refresh-lockfile": "rm -rf node_modules package-lock.json && npm install",
    "deps:status": "npm outdated || true"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^5.2.6",
    "@testing-library/user-event": "^14.6.1",
    "@types/debug": "^4.1.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/pako": "^2.0.4",
    "@types/umami-browser": "^2.18.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/eslint-plugin": "^1.6.16",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.1",
    "eslint-plugin-testing-library": "^7.16.2",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "sharp": "^0.34.5",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.0.17"
  },
  "lint-staged": {
    "*.{js,ts,svelte,json,md,css,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@lucide/svelte": "^1.14.0",
    "bits-ui": "^2.18.0",
    "browser-fs-access": "^0.38.0",
    "debug": "^4.4.3",
    "dompurify": "^3.4.2",
    "fuse.js": "^7.1.0",
    "js-yaml": "^4.1.1",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "marked": "^18.0.3",
    "nanoid": "^5.1.11",
    "pako": "^2.1.0",
    "paneforge": "^1.0.2",
    "panzoom": "^9.4.4",
    "qrcode": "^1.5.4",
    "simple-icons": "^16.18.0",
    "vaul-svelte": "^1.0.0-next.7",
    "zod": "^4.4.2"
  }
}
