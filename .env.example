# Rackula Configuration
# Copy this file to .env and customize as needed

# === Runtime (Docker Compose) ===
# Host port for frontend container
RACKULA_PORT=8080
# IPv6 listen directive: auto (detect from /proc/net/if_inet6) | true | false
RACKULA_ENABLE_IPV6=auto
# nginx listen port inside container
RACKULA_LISTEN_PORT=8080
# API sidecar listen port
RACKULA_API_PORT=3001
# Optional image overrides (useful for branch/dev tags)
# Production recommendation: pin specific release tags (not :latest),
# then update them deliberately during releases for reproducible deploys.
RACKULA_IMAGE=ghcr.io/rackulalives/rackula:latest
RACKULA_API_IMAGE=ghcr.io/rackulalives/rackula-api:latest

# API CORS policy
# Set to your exact browser origin in production (scheme + host + optional port)
CORS_ORIGIN=http://localhost:8080
# Keep false unless you explicitly need wildcard CORS in production
ALLOW_INSECURE_CORS=false

# Optional bearer token required for API PUT/DELETE routes
# Leave empty to disable write-route token enforcement
RACKULA_API_WRITE_TOKEN=

# Authentication mode for self-hosted deployments:
# - none (default): no auth gate
# - oidc: provider-backed auth via OIDC identity provider
# - local: username/password auth (single admin account)
RACKULA_AUTH_MODE=none

# Local auth (required when RACKULA_AUTH_MODE=local)
# RACKULA_LOCAL_USERNAME=admin
# RACKULA_LOCAL_PASSWORD=         # minimum 12 characters

# When RACKULA_AUTH_MODE is not "none", auth startup will fail without this value.
# Use a strong random secret (minimum 32 characters; 32+ random bytes recommended).
# Example: RACKULA_AUTH_SESSION_SECRET=$(openssl rand -hex 32)
RACKULA_AUTH_SESSION_SECRET=

# Session hardening defaults (applies when auth mode is enabled)
# Absolute session lifetime in seconds (default: 12 hours)
RACKULA_AUTH_SESSION_MAX_AGE_SECONDS=43200
# Idle timeout in seconds (default: 30 minutes)
RACKULA_AUTH_SESSION_IDLE_TIMEOUT_SECONDS=1800
# Session generation counter used for global session invalidation.
# Increment by 1 after security incidents, credential rotation, auth-token format changes,
# or whenever you need to force logout of all active sessions.
RACKULA_AUTH_SESSION_GENERATION=0
# SameSite policy for auth session cookie: Lax, Strict, or None.
# If set to None, you must also set RACKULA_AUTH_SESSION_COOKIE_SECURE=true.
RACKULA_AUTH_SESSION_COOKIE_SAMESITE=Lax
# Optional explicit override for Secure cookie flag.
# If unset: true when NODE_ENV="production", otherwise false.
# Production HTTPS deployments should set this to true explicitly.
# RACKULA_AUTH_SESSION_COOKIE_SECURE=true
# CSRF protection for state-changing, cookie-authenticated requests
RACKULA_AUTH_CSRF_PROTECTION=true

# Optional nginx proxy override (default internal API service name)
API_HOST=rackula-api

# === Local Development ===
